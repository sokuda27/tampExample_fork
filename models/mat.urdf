<?xml version="1.0"?>
<robot name="mat">
  <link name="base_link">
  <contact>
      <lateral_friction value="0.5"/>
  </contact>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0" />
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.15 0.15 0.01" />
      </geometry>
      <material name="redish">
        <color rgba="0.9 0.2 0.2 0.6" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.15 0.15 0.01" />
      </geometry>
    </collision>
  </link>
</robot>
